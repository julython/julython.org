package components

import (
	"context"
	"fmt"
	"strings"
	"time"

	"github.com/invopop/ctxi18n/i18n"

	"july/internal/components/icons"
)

// ============================================
// Types
// ============================================

type ProjectEntry struct {
	ID          string
	Name        string
	Slug        string
	URL         string
	Description string
	Service     string
	Forks       int
	Watchers    int
	Forked      bool
}

type ProjectBoardStats struct {
	CommitCount      int
	ContributorCount int
}

type ProjectGameActivitySummary struct {
	HasGame          bool
	Board            *ProjectBoardStats
	CommitsThisMonth int
	CommitsThisWeek  int
	FileTouchCount   int
	UniqueDirs       int
}

type ProjectAnalysisTile struct {
	MetricKey     string
	Level         int16
	Score         int16
	I18nKey       string
	ShowMetricAI  bool
}

type ProjectAnalysisBoard struct {
	Tiles                 []ProjectAnalysisTile
	EarnedPts             int
	MaxPts                int
	LastAnalyzedAgo       string
	AnalysisRunCount      int
	RescanL1Slug           string
	RescanL1Disabled       bool
	RescanL1DisabledReason string
}

func (b ProjectAnalysisBoard) ProgressPct() int {
	if b.MaxPts <= 0 {
		return 0
	}
	return (b.EarnedPts * 100) / b.MaxPts
}

type CommitEntry struct {
	ID         string
	Hash       string
	Message    string
	Author     string
	URL        string
	Timestamp  time.Time
	Languages  []string
	IsVerified bool
	IsFlagged  bool
	FlagReason string
}

func (c CommitEntry) ShortHash() string {
	if len(c.Hash) >= 7 {
		return c.Hash[:7]
	}
	return c.Hash
}

func (c CommitEntry) ShortMessage() string {
	msg := strings.SplitN(c.Message, "\n", 2)[0]
	if len(msg) > 120 {
		return msg[:117] + "..."
	}
	return msg
}

// ============================================
// Project List
// ============================================

type ProjectListData struct {
	Entries    []ProjectEntry
	Search     string
	Service    string
	NextCursor string
	HasMore    bool
}

// listURL builds the HTMX URL preserving current search/service params.
func (d ProjectListData) listURL() string {
	params := []string{}
	if d.Search != "" {
		params = append(params, fmt.Sprintf("search=%s", d.Search))
	}
	if d.Service != "" {
		params = append(params, fmt.Sprintf("service=%s", d.Service))
	}
	if d.NextCursor != "" {
		params = append(params, fmt.Sprintf("cursor=%s", d.NextCursor))
	}
	if len(params) == 0 {
		return "/projects"
	}
	return "/projects?" + strings.Join(params, "&")
}

templ ProjectListPage(layout LayoutData, data ProjectListData) {
	@Layout(layout) {
		<section class="max-w-5xl mx-auto px-4 py-12">
			<header class="mb-8">
				<h1 class="text-3xl font-bold text-white mb-2">{ i18n.T(ctx, "Projects") }</h1>
				<p class="text-gray-400">{ i18n.T(ctx, "ProjectsSubtitle") }</p>
			</header>
			<!-- Search + filter bar -->
			<div class="mb-6 flex flex-col sm:flex-row gap-3">
				<input
					type="search"
					name="search"
					value={ data.Search }
					placeholder={ i18n.T(ctx, "projects.SearchProjects") }
					hx-get="/projects"
					hx-trigger="input changed delay:400ms, search"
					hx-target="#projects"
					hx-swap="innerHTML"
					hx-push-url="true"
					hx-include="[name='service-filter']:checked"
					class="flex-1 px-4 py-2 rounded-lg bg-surface-light border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-july-500/50 transition-colors text-sm"
				/>
				<div class="flex gap-2 shrink-0">
					@serviceFilterPill("", data.Service, i18n.T(ctx, "projects.AllServices"))
					@serviceFilterPill("github", data.Service, "GitHub")
					@serviceFilterPill("gitlab", data.Service, "GitLab")
				</div>
			</div>
			<div id="projects">
				@ProjectListItems(data)
			</div>
		</section>
	}
}

// serviceFilterPill renders a toggle pill for the service filter.
// It uses a hidden radio input so hx-include picks it up by name.
templ serviceFilterPill(value, current, label string) {
	<label
		class={
			"cursor-pointer px-4 py-2 rounded-lg text-sm font-medium border transition-colors",
			templ.KV("bg-july-500/20 border-july-500/50 text-july-300", value == current),
			templ.KV("bg-surface-light border-white/10 text-gray-400 hover:text-white hover:border-white/20", value != current),
		}
	>
		<input
			type="radio"
			name="service-filter"
			value={ value }
			class="sr-only"
			if value == current {
				checked
			}
			hx-get="/projects"
			hx-trigger="change"
			hx-target="#projects"
			hx-swap="innerHTML"
			hx-push-url="true"
			hx-include="[name='search']"
		/>
		{ label }
	</label>
}

// ProjectListItems is the partial returned for both HTMX search/filter requests
// and the infinite-scroll sentinel swap. It renders the cards plus a sentinel
// div that triggers the next page load when scrolled into view.
templ ProjectListItems(data ProjectListData) {
	if len(data.Entries) == 0 {
		<div class="text-center py-16 bg-surface-light rounded-xl border border-white/10">
			<span class="text-6xl mb-4 block">📦</span>
			<p class="text-gray-400">{ i18n.T(ctx, "NoProjects") }</p>
		</div>
	} else {
		<div class="grid gap-4">
			for _, entry := range data.Entries {
				@ProjectCard(entry)
			}
		</div>
		if data.HasMore {
			<!-- Sentinel: replaced by the next page of items when scrolled into view -->
			<div
				hx-get={ data.listURL() }
				hx-trigger="revealed"
				hx-swap="outerHTML"
				class="py-8 flex justify-center"
			>
				<span class="text-gray-600 text-sm animate-pulse">{ i18n.T(ctx, "LoadingMore") }</span>
			</div>
		}
	}
}

templ ProjectCard(entry ProjectEntry) {
	<div class="bg-surface-light rounded-xl border border-white/10 p-5 hover:border-july-500/40 transition-colors group">
		<div class="flex items-start justify-between gap-4">
			<a href={ templ.SafeURL(fmt.Sprintf("/projects/%s", entry.Slug)) } class="min-w-0 flex-1">
				<div class="flex items-center gap-2 mb-1">
					<h2 class="font-semibold text-white group-hover:text-july-400 transition-colors truncate">
						{ entry.Name }
					</h2>
					if entry.Forked {
						<span class="shrink-0 text-xs px-2 py-0.5 rounded-full bg-white/10 text-gray-400">
							{ i18n.T(ctx, "Fork") }
						</span>
					}
				</div>
				if entry.Description != "" {
					<p class="text-sm text-gray-400 line-clamp-2">{ entry.Description }</p>
				}
				<p class="text-xs text-gray-600 mt-2">{ entry.Slug }</p>
			</a>
			<div class="shrink-0 flex flex-col items-end gap-2">
				<a
					href={ templ.SafeURL(entry.URL) }
					target="_blank"
					rel="noopener noreferrer"
					class="text-xs px-3 py-1 rounded-lg bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-colors"
				>
					{ serviceLabel(ctx, entry.Service) }
				</a>
				<div class="flex items-center gap-3 text-xs text-gray-500">
					<span title={ i18n.T(ctx, "Forks") }>⑂ { fmt.Sprintf("%d", entry.Forks) }</span>
					<span title={ i18n.T(ctx, "Watchers") }>👁 { fmt.Sprintf("%d", entry.Watchers) }</span>
				</div>
			</div>
		</div>
	</div>
}

// ============================================
// Project Detail
// ============================================

type ProjectDetailData struct {
	Project       ProjectEntry
	AnalysisBoard ProjectAnalysisBoard
	GameActivity  ProjectGameActivitySummary
	Commits       []CommitEntry
	Offset        int
	Limit         int
	HasMore       bool
}

templ ProjectDetailPage(layout LayoutData, data ProjectDetailData) {
	@Layout(layout) {
		<section>
			<div class="max-w-5xl mx-auto px-4 pt-12">
				<header class="mb-8">
					<div class="flex items-start justify-between gap-4 flex-wrap">
						<div>
							<div class="flex items-center gap-2 mb-1">
								<h1 class="text-3xl font-bold text-white">{ data.Project.Name }</h1>
								if data.Project.Forked {
									<span class="text-sm px-2 py-0.5 rounded-full bg-white/10 text-gray-400">
										{ i18n.T(ctx, "Fork") }
									</span>
								}
							</div>
							if data.Project.Description != "" {
								<p class="text-gray-400 mt-1">{ data.Project.Description }</p>
							}
							<p class="text-sm text-gray-600 mt-1">{ data.Project.Slug }</p>
						</div>
						<div class="flex flex-col sm:flex-row gap-2 sm:gap-3 items-stretch sm:items-center shrink-0">
							<a
								href={ templ.SafeURL(data.Project.URL) }
								target="_blank"
								rel="noopener noreferrer"
								class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-white/5 text-gray-300 hover:bg-white/10 hover:text-white transition-colors border border-white/10"
							>
								{ serviceLabel(ctx, data.Project.Service) }
							</a>
						</div>
					</div>
				</header>
			</div>
			@projectStatsBar(data)
			<div class="max-w-5xl mx-auto px-4 pb-12 pt-6">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8 items-start">
				<div class="min-w-0 flex lg:col-span-1">
					@projectAnalysisBoard(data.AnalysisBoard)
				</div>
				<div class="min-w-0 flex lg:col-span-2">
					@projectChatPanel(data)
				</div>
			</div>
			<div class="flex items-center justify-between mb-4">
				<h2 class="text-xl font-semibold text-white">{ i18n.T(ctx, "RecentCommits") }</h2>
			</div>
			<div id="commits">
				@ProjectCommitList(data)
			</div>
			</div>
		</section>
	}
}

templ ProjectCommitList(data ProjectDetailData) {
	if len(data.Commits) == 0 {
		<div class="text-center py-12 bg-surface-light rounded-xl border border-white/10">
			<span class="text-5xl mb-3 block">📭</span>
			<p class="text-gray-400">{ i18n.T(ctx, "NoCommits") }</p>
		</div>
	} else {
		<div class="bg-surface-light rounded-xl border border-white/10 overflow-hidden divide-y divide-white/5">
			for _, c := range data.Commits {
				@CommitRow(c)
			}
		</div>
		if data.HasMore {
			<div class="mt-6 text-center">
				<button
					hx-get={ fmt.Sprintf("/projects/%s?offset=%d", data.Project.Slug, data.Offset+data.Limit) }
					hx-target="#commits"
					hx-swap="innerHTML"
					class="px-6 py-3 bg-surface-light text-gray-300 rounded-lg font-medium hover:bg-surface-lighter transition-colors border border-white/10"
				>
					{ i18n.T(ctx, "LoadMore") }
				</button>
			</div>
		}
	}
}

templ CommitRow(c CommitEntry) {
	<div class={ "px-5 py-4 hover:bg-white/5 transition-colors", templ.KV("opacity-50", c.IsFlagged) }>
		<div class="flex items-start justify-between gap-4">
			<div class="min-w-0">
				<p class="text-white text-sm font-medium truncate mb-1">{ c.ShortMessage() }</p>
				<div class="flex items-center flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500">
					<span>{ c.Author }</span>
					<span>{ c.Timestamp.Format("Jan 2, 2006") }</span>
					if len(c.Languages) > 0 {
						<span class="text-gray-600">{ strings.Join(c.Languages, " · ") }</span>
					}
					if c.IsFlagged {
						<span class="text-red-400">⚑ { i18n.T(ctx, "Flagged") }</span>
					}
				</div>
			</div>
			<div class="shrink-0 flex items-center gap-2">
				if c.IsVerified {
					<span class="text-xs px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/20">
						✓ { i18n.T(ctx, "Verified") }
					</span>
				}
				<a
					href={ templ.SafeURL(c.URL) }
					target="_blank"
					rel="noopener noreferrer"
					class="font-mono text-xs px-2 py-1 rounded bg-white/5 text-july-400 hover:bg-white/10 transition-colors"
					title={ c.Hash }
				>
					{ c.ShortHash() }
				</a>
			</div>
		</div>
	</div>
}

// ============================================
// Analysis board (project detail)
// ============================================

templ analysisDash(level int16, dashIdx int) {
	if level >= 3 {
		<span class="h-0.5 flex-1 max-w-[1.1rem] rounded-full bg-green-400"></span>
	} else if level <= 0 {
		<span class="h-0.5 flex-1 max-w-[1.1rem] rounded-full bg-zinc-600"></span>
	} else if int16(dashIdx) <= level {
		<span class="h-0.5 flex-1 max-w-[1.1rem] rounded-full bg-blue-400"></span>
	} else {
		<span class="h-0.5 flex-1 max-w-[1.1rem] rounded-full bg-zinc-600/80"></span>
	}
}

templ analysisMetricTile(tile ProjectAnalysisTile) {
	<div
		class={
			"rounded-md px-1.5 py-1.5 border transition-colors min-w-0",
			templ.KV("border-green-500/45 bg-green-500/[0.07]", tile.Level >= 3),
			templ.KV("border-blue-500/40 bg-blue-500/[0.06]", tile.Level >= 1 && tile.Level < 3),
			templ.KV("border-white/10 bg-white/[0.02]", tile.Level < 1),
		}
	>
		<div class="flex gap-0.5 mb-1 justify-center">
			@analysisDash(tile.Level, 1)
			@analysisDash(tile.Level, 2)
			@analysisDash(tile.Level, 3)
		</div>
		<p
			class={
				"text-[10px] sm:text-[11px] font-medium text-center leading-tight tracking-tight",
				templ.KV("text-green-300", tile.Level >= 3),
				templ.KV("text-blue-200", tile.Level >= 1 && tile.Level < 3),
				templ.KV("text-gray-500", tile.Level < 1),
			}
		>
			{ i18n.T(ctx, tile.I18nKey) }
		</p>
		<p class="text-[9px] text-gray-600 text-center tabular-nums mt-0.5">{ fmt.Sprintf("%d/10", tile.Score) }</p>
		if tile.ShowMetricAI {
			<button
				type="button"
				class="metric-ai-btn mt-1 w-full text-[9px] font-medium py-0.5 rounded border border-july-500/30 text-july-300/90 hover:bg-july-500/15 transition-colors"
				data-metric-key={ tile.MetricKey }
			>
				AI
			</button>
		}
	</div>
}

templ projectChatPanel(data ProjectDetailData) {
	<div class="rounded-xl border border-white/10 bg-surface-light/80 overflow-hidden flex flex-col flex-1 w-full min-h-[420px]">
		<div class="px-3 sm:px-4 py-2.5 border-b border-white/10 flex flex-wrap items-center justify-between gap-x-3 gap-y-2">
			<h2 class="text-xs font-semibold tracking-wide text-gray-400 uppercase shrink-0">{ i18n.T(ctx, "projects.Assistant") }</h2>
			<div class="flex flex-wrap items-center gap-2 min-w-0 flex-1 sm:flex-initial sm:justify-end">
				<label for="llm-model-select" class="sr-only">{ i18n.T(ctx, "projects.BrowserModel") }</label>
				<select
					id="llm-model-select"
					class="text-xs px-2 py-1.5 rounded-md bg-black/25 border border-white/10 text-gray-300 min-w-[10rem] max-w-[min(100vw-8rem,18rem)] focus:outline-none focus:border-july-500/50"
				></select>
				<button
					type="button"
					id="llm-cache-clear"
					class="hidden text-xs px-2 py-1.5 rounded-md bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition-colors whitespace-nowrap shrink-0"
					title={ i18n.T(ctx, "projects.ClearModelCache") }
				>
					{ i18n.T(ctx, "projects.ClearModelCache") }
				</button>
			</div>
		</div>
		<p class="px-4 pt-3 pb-1 text-[11px] text-gray-500 leading-snug">{ i18n.T(ctx, "projects.AssistantHint") }</p>
		<div
			id="analyzer"
			class="flex flex-col flex-1 min-h-0"
			data-repo-url={ data.Project.URL }
			data-project-id={ data.Project.ID }
			data-llm-worker-url={ AssetLLMWorker }
			data-repo-name={ githubRepoPath(data.Project.URL) }
			data-repo-description={ data.Project.Description }
		></div>
		<script type="module" src={ AssetAnalyzer }></script>
	</div>
}

templ projectStatsBar(data ProjectDetailData) {
	<div class="w-full border-y border-white/10 bg-black/25">
		<div class="max-w-5xl mx-auto px-2 py-1.5 sm:px-3">
			<div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 text-[11px] sm:text-xs">
				<div class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
					<span class="text-gray-500">{ i18n.T(ctx, "Points") }</span>
					<span class="text-gray-200 tabular-nums font-medium">
						{ fmt.Sprintf("%d", data.AnalysisBoard.EarnedPts) } / { fmt.Sprintf("%d", data.AnalysisBoard.MaxPts) }
					</span>
				</div>
				if data.AnalysisBoard.LastAnalyzedAgo != "" {
					<span class="text-gray-500">
						{ i18n.T(ctx, "projects.LastAnalyzed") }:
						<span class="text-gray-300 ml-1">{ data.AnalysisBoard.LastAnalyzedAgo }</span>
						<span class="text-gray-600 ml-1">
							({ fmt.Sprintf("%d", data.AnalysisBoard.AnalysisRunCount) } { i18n.T(ctx, "projects.AnalysesTotal") })
						</span>
					</span>
				} else {
					<span class="text-gray-600">{ i18n.T(ctx, "projects.NeverAnalyzed") }</span>
				}
			</div>
			<div class="mt-1 flex flex-wrap gap-x-5 gap-y-0.5 text-[11px] text-gray-400">
				if !data.GameActivity.HasGame {
					<span>{ i18n.T(ctx, "projects.NoGameData") }</span>
				} else {
					if data.GameActivity.Board != nil {
						<span>
							<span class="text-gray-500">{ i18n.T(ctx, "projects.GameCommits") }:</span>
							<span class="text-gray-200 tabular-nums ml-1">{ fmt.Sprintf("%d", data.GameActivity.Board.CommitCount) }</span>
						</span>
						<span>
							<span class="text-gray-500">{ i18n.T(ctx, "Contributors") }:</span>
							<span class="text-gray-200 tabular-nums ml-1">{ fmt.Sprintf("%d", data.GameActivity.Board.ContributorCount) }</span>
						</span>
					}
					<span>
						<span class="text-gray-500">{ i18n.T(ctx, "projects.CommitsThisMonth") }:</span>
						<span class="text-gray-200 tabular-nums ml-1">{ fmt.Sprintf("%d", data.GameActivity.CommitsThisMonth) }</span>
						<span class="text-gray-600 ml-1">(+{ fmt.Sprintf("%d", data.GameActivity.CommitsThisWeek) } { i18n.T(ctx, "projects.ThisWeek") })</span>
					</span>
					<span>
						<span class="text-gray-500">{ i18n.T(ctx, "projects.FilesAndLines") }:</span>
						<span class="text-gray-200 tabular-nums ml-1">{ fmt.Sprintf("%d", data.GameActivity.FileTouchCount) }</span>
						if data.GameActivity.UniqueDirs > 0 {
							<span class="text-gray-600 ml-1">
								({ fmt.Sprintf("%d", data.GameActivity.UniqueDirs) } { i18n.T(ctx, "projects.UniqueDirs") })
							</span>
						}
					</span>
				}
			</div>
		</div>
	</div>
}

templ projectAnalysisBoard(board ProjectAnalysisBoard) {
	<div class="rounded-xl border border-white/10 bg-surface-light/80 overflow-hidden flex flex-col flex-1 w-full">
		<div class="px-3 py-2 border-b border-white/10">
			<h2 class="text-xs font-semibold tracking-wide text-gray-400 uppercase">{ i18n.T(ctx, "projects.AnalysisBoard") }</h2>
		</div>
		<div class="p-2.5 sm:p-3 space-y-3">
			<div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
				for _, tile := range board.Tiles {
					@analysisMetricTile(tile)
				}
			</div>
			<div>
				<div class="flex items-center justify-between text-[10px] sm:text-xs mb-1">
					<span class="text-gray-500">{ i18n.T(ctx, "Points") }</span>
					<span class="text-gray-300 tabular-nums font-medium">
						{ fmt.Sprintf("%d", board.EarnedPts) } / { fmt.Sprintf("%d", board.MaxPts) } pts
					</span>
				</div>
				<div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
					<div
						class="h-full rounded-full bg-green-500/80 transition-all"
						style={ fmt.Sprintf("width: %d%%", board.ProgressPct()) }
					></div>
				</div>
			</div>
			<div class="border-t border-white/10 pt-2.5">
				<p class="text-gray-500 text-[10px] sm:text-xs mb-0.5">{ i18n.T(ctx, "projects.LastAnalyzed") }</p>
				<p class="text-white text-xs leading-snug">
					if board.LastAnalyzedAgo != "" {
						{ board.LastAnalyzedAgo }
						<span class="text-gray-500 font-normal">
							({ fmt.Sprintf("%d", board.AnalysisRunCount) } { i18n.T(ctx, "projects.AnalysesTotal") })
						</span>
					} else {
						<span class="text-gray-500">{ i18n.T(ctx, "projects.NeverAnalyzed") }</span>
					}
				</p>
			</div>
			if board.RescanL1Slug != "" {
				<div class="border-t border-white/10 pt-2.5">
					<button
						type="button"
						hx-post={ fmt.Sprintf("/projects/%s/analysis/l1", board.RescanL1Slug) }
						hx-swap="none"
						hx-disabled-elt="this"
						if board.RescanL1Disabled {
							disabled
						}
						if board.RescanL1Disabled {
							title={ l1RescanTitle(ctx, board.RescanL1DisabledReason) }
						}
						class={
							"w-full text-xs font-medium py-2 px-3 rounded-lg border transition-colors group disabled:opacity-60 disabled:cursor-not-allowed",
							templ.KV("bg-july-500/15 border-july-500/35 text-july-200 hover:bg-july-500/25", !board.RescanL1Disabled),
							templ.KV("bg-white/5 border-white/10 text-gray-500 cursor-not-allowed", board.RescanL1Disabled),
						}
					>
						<span class="htmx-idle flex items-center justify-center gap-1.5 w-full">
							{ i18n.T(ctx, "projects.RescanL1") }
						</span>
						<span class="htmx-busy items-center justify-center gap-1.5 w-full">
							@icons.SpinnerIcon()
							<span>{ i18n.T(ctx, "projects.RescanL1Running") }</span>
						</span>
					</button>
				</div>
			}
		</div>
	</div>
}

func l1RescanTitle(ctx context.Context, reason string) string {
	switch reason {
	case "private":
		return i18n.T(ctx, "projects.RescanL1DisabledPrivate")
	case "no_token":
		return i18n.T(ctx, "projects.RescanL1DisabledNoToken")
	default:
		return ""
	}
}

// githubRepoPath returns "owner/repo" for GitHub URLs, or the cleaned path for other hosts.
func githubRepoPath(url string) string {
	u := strings.TrimSpace(url)
	u = strings.TrimPrefix(u, "https://github.com/")
	u = strings.TrimPrefix(u, "http://github.com/")
	u = strings.TrimSuffix(u, "/")
	u = strings.TrimSuffix(u, ".git")
	if u == "" {
		return url
	}
	return u
}

// ============================================
// Shared helpers
// ============================================

func serviceLabel(ctx context.Context, service string) string {
	switch strings.ToLower(service) {
	case "github":
		return i18n.T(ctx, "ViewOnGitHub") + " ↗"
	case "gitlab":
		return i18n.T(ctx, "ViewOnGitLab") + " ↗"
	default:
		return i18n.T(ctx, "ViewOnService") + " ↗"
	}
}
