# Database
PROD_DATABASE_URL=postgres://july:july@localhost:5432/july?sslmode=disable

# Server
JULY_PORT=8080

# GitHub OAuth (for user login)
JULY_GITHUB_CLIENT_ID=your_client_id
JULY_GITHUB_CLIENT_SECRET=your_client_secret
JULY_GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback

# Session secret
JULY_SESSION_SECRET=change-me-in-production

# Encryption key (required for database encryption)
# Generate a 32-byte hex-encoded key: openssl rand -hex 32
JULY_DATABASE_ENC_KEY=

# Optional: Redis for sessions
JULY_REDIS_URL=redis://localhost:6379